{
  "name": "@comply-ai/core",
  "version": "0.2.0",
  "description": "Open-source EU AI Act compliance engine — risk classification, checklists, and model card generation",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "eu-ai-act",
    "compliance",
    "risk-classification",
    "ai-governance",
    "model-card",
    "regulation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/antonmacius-droid/comply-ai"
  }
}
