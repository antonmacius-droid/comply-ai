{
  "name": "@comply-ai/cli",
  "version": "0.1.0",
  "description": "CLI for EU AI Act compliance — classify risk, run checks, generate model cards",
  "license": "MIT",
  "type": "module",
  "bin": {
    "comply-ai": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --banner.js '#!/usr/bin/env node'",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@comply-ai/core": "*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "conf": "^13.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "eu-ai-act",
    "compliance",
    "cli",
    "risk-classification",
    "ai-governance"
  ]
}
